Options -Indexes
ServerSignature Off

# PHP errors - production'da kapalı tut
php_flag display_errors Off
php_flag log_errors On

# Tüm istekleri public/index.php'ye yönlendir
RewriteEngine On

# 1) Sadece gerçek DOSYALARI direkt sun (klasörleri değil)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2) Admin isteklerini admin/index.php'ye yönlendir
RewriteCond %{REQUEST_URI} ^/admin
RewriteRule ^ admin/index.php [QSA,L]

# 3) Geri kalanı public/index.php'ye yönlendir
RewriteRule ^(.*)$ public/index.php [QSA,L]

# Güvenlik: hassas dosyaları engelle
<FilesMatch "\.(sql|log|env|json|md|gitignore)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# app/ klasörüne doğrudan erişimi engelle
RewriteRule ^app/ - [F,L]
RewriteRule ^database/ - [F,L]

# Resim hotlink koruması (opsiyonel - kendi domain'ini gir)
# RewriteCond %{HTTP_REFERER} !^https?://(www\.)?cakmaklar\.com [NC]
# RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F,NC]

# MIME türleri
AddType application/javascript .js
AddType text/css .css
AddType image/webp .webp

# Gzip sıkıştırma
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Cache ayarları
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
